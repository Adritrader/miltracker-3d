# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001

# ─── ADS-B data (NO registration needed for any of these)
# Primary:  https://api.adsb.lol/v2/mil
# Fallback: https://opendata.adsb.fi/api/v2/mil
# Fallback: https://api.airplanes.live/v2/mil
# All three are free, public, no API key required.

# ─── Cesium Ion (for satellite imagery)
# Free at: https://ion.cesium.com/ (1GB/month free)
CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ─── Google Gemini AI (free: 1500 req/day)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── NewsAPI (free: 100 req/day)
# Free account: https://newsapi.org/register
NEWSAPI_KEY=

# ─── AISStream.io (free WebSocket AIS data - optional upgrade for ships)
# Free account: https://aisstream.io
AISSTREAM_KEY=

# ─── NASA FIRMS (free thermal anomaly / explosion detection)
# Register at: https://firms.modaps.eosdis.nasa.gov/api/area/
# Then copy your MAP_KEY here. Without this key FIRMS data is silently skipped.
FIRMS_MAP_KEY=
