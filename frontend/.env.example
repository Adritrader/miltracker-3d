# ─── Cesium Ion token (for satellite imagery)
# Free at: https://ion.cesium.com/ — 1GB/month free
# Without this, falls back to OpenStreetMap (no satellite)
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ─── Backend URL (required in production)
# Deploy backend to Railway/Render and paste the URL here
# In Vercel dashboard → Settings → Environment Variables
VITE_BACKEND_URL=https://your-backend.railway.app

# ─── Supabase (required for auth — login, register, Google OAuth)
# Create a project at https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Google reCAPTCHA v2 site key (required for register form)
# Create at https://www.google.com/recaptcha/admin — choose reCAPTCHA v2 "I'm not a robot"
# Add your domain + localhost to the allowed list
# The secret key goes in the BACKEND environment (RECAPTCHA_SECRET_KEY)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
