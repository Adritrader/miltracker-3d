# ─── Cesium Ion token (for satellite imagery)
# Free at: https://ion.cesium.com/ — 1GB/month free
# Without this, falls back to OpenStreetMap (no satellite)
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ─── Backend URL (required in production)
# Deploy backend to Railway/Render and paste the URL here
# In Vercel dashboard → Settings → Environment Variables
VITE_BACKEND_URL=https://your-backend.railway.app
